# ── Copia a .env.local (nunca subas .env.local al repositorio).

# URL canónica del sitio (Open Graph / metadata)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app

# Catálogo público
NEXT_PUBLIC_CATALOGO_URL=https://catalogo.vedisaremates.cl/

# Video hero “Cómo participar” (YouTube ID)
NEXT_PUBLIC_HERO_YOUTUBE_ID=2BLLkGCIQWI

# Carrusel home: JSON opcional [{ "src": "https://...", "href": "/", "alt": "..." }, ...]
# NEXT_PUBLIC_HERO_SLIDES_JSON=

# HubSpot (formulario contacto) — región eu1 o na1 según portal
NEXT_PUBLIC_HUBSPOT_REGION=eu1
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_FORM_ID=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_RAW=

SUPABASE_SERVICE_ROLE_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
PIPEDRIVE_API_KEY=
WEBHOOK_URL=
GLO3D_API_URL=https://glo3d.net/api
GLO3D_API_USERNAME=
GLO3D_API_PASSWORD=
