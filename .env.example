# ── Copia a .env.local (nunca subas .env.local al repositorio).
# Si alguna clave llegó a exponerse públicamente, rodala en el panel de cada servicio.

# --- Público en el navegador (prefijo NEXT_PUBLIC_) ---
NEXT_PUBLIC_CATALOGO_URL=https://catalogo.vedisaremates.cl/

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudinary (subidas desde el cliente si las usas así; ver docs de tu flujo)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_RAW=

# --- Solo servidor / API routes / scripts (nunca NEXT_PUBLIC_) ---
SUPABASE_SERVICE_ROLE_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

PIPEDRIVE_API_KEY=

# Webhook destino (ej. Edge Function SES)
WEBHOOK_URL=

GLO3D_API_URL=https://glo3d.net/api
GLO3D_API_USERNAME=
GLO3D_API_PASSWORD=
