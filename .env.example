# ── Copia a .env.local (nunca subas .env.local al repositorio).

# URL canónica del sitio (Open Graph / metadata)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app

# Catálogo público
NEXT_PUBLIC_CATALOGO_URL=https://catalogo.vedisaremates.cl/

# Video hero “Cómo participar” (YouTube ID)
NEXT_PUBLIC_HERO_YOUTUBE_ID=2BLLkGCIQWI

# Carrusel home: JSON opcional [{ "src": "https://...", "href": "/", "alt": "..." }] — si existe, tiene prioridad sobre la tabla portal_home_hero.
# NEXT_PUBLIC_HERO_SLIDES_JSON=

# Cloudinary (subida banners admin / Personalizar — preset UNSIGNED en Cloudinary Dashboard)

# HubSpot (formulario contacto) — región eu1 o na1 según portal
NEXT_PUBLIC_HUBSPOT_REGION=eu1
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_FORM_ID=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# O bien (misma instancia Tasaciones Vedisa/Vite): VITE_SUPABASE_URL y VITE_SUPABASE_ANON_KEY — next.config.ts los acepta.
# Si usás solo las VITE_*, igual completá valores de producción antes de npm run build.
# Subastas portal: ejecutá una vez el SQL → supabase/migrations/portal_subastas_vedisaremates.sql

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_RAW=
# O en Vercel (mismo valor): VITE_CLOUDINARY_CLOUD_NAME, VITE_CLOUDINARY_UPLOAD_PRESET, VITE_CLOUDINARY_UPLOAD_PRESET_RAW — next.config.ts las expone como NEXT_PUBLIC_* al compilar.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=no-reply@vedisaremates.cl
AWS_SES_REPLY_TO=pagos@vedisaremates.cl
PIPEDRIVE_API_KEY=
WEBHOOK_URL=
GLO3D_API_URL=https://glo3d.net/api
GLO3D_API_USERNAME=
GLO3D_API_PASSWORD=
# Autored (precio referencial de publicación; mismas credenciales que Edge autored-vehicle-info en Tasaciones)
# AUTORED_EMAIL=
# AUTORED_PASSWORD=
